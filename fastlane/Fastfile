# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools

default_platform(:ios)

platform :ios do
  desc "Build the project"
  lane :build do
    # 动态获取iOS版本，支持环境变量配置
    ios_version = ENV["IOS_VERSION"] || "18.6"
    device_name = ENV["DEVICE_NAME"] || "iPhone 16"
    destination = "platform=iOS Simulator,OS=#{ios_version},name=#{device_name}"
    
    UI.message("📱 使用 iOS 版本: #{ios_version}")
    UI.message("📲 目标设备: #{device_name}")
    UI.message("🎯 构建目标: #{destination}")
    
    build_ios_app(
      project: "ZHKLine.xcodeproj",
      scheme: "ZHKLine",
      destination: destination,
      sdk: "iOS #{ios_version}",
      configuration: "Debug",
      skip_package_ipa: true,
      skip_archive: true,
      codesigning_identity: "",
      xcargs: "CODE_SIGNING_REQUIRED=NO CODE_SIGN_IDENTITY='' PROVISIONING_PROFILE=''"
    )
  end

  desc "Run unit tests only"
  lane :unit_test do
    # 使用与build lane相同的动态配置
    ios_version = ENV["IOS_VERSION"] || "18.6"
    device_name = ENV["DEVICE_NAME"] || "iPhone 16"
    destination = "platform=iOS Simulator,OS=#{ios_version},name=#{device_name}"
    
    UI.message("🧪 运行单元测试 - iOS: #{ios_version}, 设备: #{device_name}")
    
    run_tests(
      project: "ZHKLine.xcodeproj",
      scheme: "ZHKLine",
      destination: destination,
      sdk: "iOS #{ios_version}",
      code_coverage: true,
      skip_build: false,
      only_testing: ["ZHKLineTests"]
    )
  end

  desc "Run UI tests only"
  lane :ui_test do
    # 使用与build lane相同的动态配置
    ios_version = ENV["IOS_VERSION"] || "18.6"
    device_name = ENV["DEVICE_NAME"] || "iPhone 16"
    destination = "platform=iOS Simulator,OS=#{ios_version},name=#{device_name}"
    
    UI.message("🎯 运行UI测试 - iOS: #{ios_version}, 设备: #{device_name}")
    
    run_tests(
      project: "ZHKLine.xcodeproj",
      scheme: "ZHKLine",
      destination: destination,
      sdk: "iOS #{ios_version}",
      code_coverage: true,
      skip_build: false,
      only_testing: ["ZHKLineUITests"]
    )
  end

  desc "Run all tests (unit + UI)"
  lane :test do
    unit_test
    ui_test
  end
end
