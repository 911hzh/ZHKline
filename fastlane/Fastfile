# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools

default_platform(:ios)

platform :ios do
  desc "Build the project"
  lane :build do
    # 根据环境使用不同的iOS版本
    # ios_version = ENV["IOS_VERSION"] || "18.3.1"
    ios_version = "18.6"
    destination = "platform=iOS Simulator,name=iPhone 16,OS=#{ios_version}"
    
    build_ios_app(
      scheme: "ZHKLine",
      configuration: "Debug",
      destination: destination,
      skip_package_ipa: true,
      skip_archive: true
    )
  end

  desc "Run unit tests only"
  lane :unit_test do
    ios_version = "18.6"
    destination = "platform=iOS Simulator,name=iPhone 16,OS=#{ios_version}"
    
    scan(
      scheme: "ZHKLine",
      destination: destination,
      only_testing: ["ZHKLineTests"]
    )
  end

  desc "Run UI tests only"
  lane :ui_test do
    ios_version = "18.6"
    destination = "platform=iOS Simulator,name=iPhone 16,OS=#{ios_version}"
    
    scan(
      scheme: "ZHKLine",
      destination: destination,
      only_testing: ["ZHKLineUITests"]
    )
  end

  desc "Run all tests (unit + UI)"
  lane :test do
    unit_test
    ui_test
  end
end
