#!/bin/bash

# Pre-commit hook for ZHKLine project
# This script runs before each commit to ensure code quality

set -e  # Exit immediately if a command exits with a non-zero status

echo "🚀 Running pre-commit checks..."

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Function to print colored output
print_status() {
    echo -e "${GREEN}✅ $1${NC}"
}

print_warning() {
    echo -e "${YELLOW}⚠️  $1${NC}"
}

print_error() {
    echo -e "${RED}❌ $1${NC}"
}

# Check if SwiftLint is installed
if ! command -v swiftlint &> /dev/null; then
    print_error "SwiftLint not found. Installing..."
    if command -v brew &> /dev/null; then
        brew install swiftlint
    else
        print_error "Homebrew not found. Please install SwiftLint manually: https://github.com/realm/SwiftLint"
        exit 1
    fi
fi

# Get list of Swift files that are staged for commit
SWIFT_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep '\.swift$' || true)

if [ -z "$SWIFT_FILES" ]; then
    print_status "No Swift files to check"
else
    print_status "Checking Swift files with SwiftLint..."
    
    # Run SwiftLint on staged files
    echo "$SWIFT_FILES" | xargs swiftlint lint --quiet
    SWIFTLINT_EXIT_CODE=$?
    
    if [ $SWIFTLINT_EXIT_CODE -ne 0 ]; then
        print_error "SwiftLint found issues. Please fix them before committing."
        print_warning "You can run 'swiftlint --fix' to automatically fix some issues."
        exit 1
    else
        print_status "SwiftLint passed"
    fi
fi

# Check for TODO and FIXME comments in staged files
print_status "Checking for TODO/FIXME comments..."
TODO_COUNT=$(git diff --cached --name-only --diff-filter=ACMR | grep '\.swift$' | xargs grep -n "TODO\|FIXME" 2>/dev/null | wc -l || echo "0")

if [ "$TODO_COUNT" -gt 0 ]; then
    print_warning "Found $TODO_COUNT TODO/FIXME comments in staged files:"
    git diff --cached --name-only --diff-filter=ACMR | grep '\.swift$' | xargs grep -n "TODO\|FIXME" 2>/dev/null || true
    echo ""
    print_warning "Consider addressing these before committing."
fi

# Check for large files
print_status "Checking for large files..."
LARGE_FILES=$(git diff --cached --name-only --diff-filter=ACMR | xargs ls -la 2>/dev/null | awk '$5 > 1048576 {print $9 " (" $5 " bytes)"}' || true)

if [ ! -z "$LARGE_FILES" ]; then
    print_warning "Large files detected (>1MB):"
    echo "$LARGE_FILES"
    print_warning "Consider using Git LFS for large files."
fi

# Check for debug prints and console.log
print_status "Checking for debug statements..."
DEBUG_STATEMENTS=$(git diff --cached --name-only --diff-filter=ACMR | grep '\.swift$' | xargs grep -n "print(\|NSLog(\|debugPrint(" 2>/dev/null | wc -l || echo "0")

if [ "$DEBUG_STATEMENTS" -gt 0 ]; then
    print_warning "Found $DEBUG_STATEMENTS debug print statements in staged files:"
    git diff --cached --name-only --diff-filter=ACMR | grep '\.swift$' | xargs grep -n "print(\|NSLog(\|debugPrint(" 2>/dev/null || true
    echo ""
    print_warning "Consider removing debug statements before committing."
fi

# Check if package.swift or project files are modified
PACKAGE_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E "(Package\.swift|\.xcodeproj)" || true)
if [ ! -z "$PACKAGE_FILES" ]; then
    print_warning "Package/Project files modified. Make sure dependencies are properly managed."
fi

print_status "All pre-commit checks passed! 🎉"
echo ""
